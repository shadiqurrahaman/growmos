# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker: postgres://growmos:growmos_secret@localhost:5432/growmos
# Neon (production): postgres://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://growmos:growmos_secret@localhost:5432/growmos

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=shaon@123
AUTH_SECRET=your-random-secret-at-least-32-characters-long

# ── SMTP (outgoing email) ─────────────────────────────────────────────────────
# cPanel hosting: host is usually mail.yourdomain.com
SMTP_HOST=mail.growmos.com
SMTP_PORT=465
SMTP_USER=hello@growmos.com
SMTP_PASS=your-cpanel-email-password
CONTACT_TO=hello@growmos.com
EMAIL_FROM_NAME=GrowMos

# ── IMAP (inbox reading) ──────────────────────────────────────────────────────
# cPanel hosting: same host as SMTP, port 993 for SSL
IMAP_HOST=mail.growmos.com
IMAP_PORT=993
IMAP_USER=hello@growmos.com
IMAP_PASS=your-cpanel-email-password

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Vercel Blob (for image uploads, optional) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercelblob_...
